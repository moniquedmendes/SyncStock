@model List<SyncStock.Models.Produto>

<h2>Produtos</h2>

<a asp-action="Cadastro" class="btn btn-success mb-3">
    Novo Produto
</a>

<table class="table table-striped">

    <thead>
        <tr>
            <th>Código</th>
            <th>Nome</th>
            <th>Categoria</th>
            <th>Marca</th>
            <th>Fornecedor</th>
            <th>Preço</th>
            <th>Estoque</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var produto in Model)
        {
            <tr>

                <td>@produto.Codigo</td>
                <td>@produto.Nome</td>
                <td>@produto.Categoria</td>
                <td>@produto.Marca</td>
                <td>@produto.Fornecedor</td>
                <td>@produto.Preco</td>
                <td>@produto.QuantidadeEstoque</td>

                <td>

                    <a asp-action="Edit" asp-route-id="@produto.Id" class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Inativar" asp-route-id="@produto.Id" class="btn btn-danger btn-sm">
                        Inativar
                    </a>

                </td>

            </tr>
        }
    </tbody>


</table>